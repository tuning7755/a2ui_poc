LITELLM_MODEL=openai/qwen-plus
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=dummy
LITELLM_TEMPERATURE=0.1
LITELLM_TIMEOUT=60

# LLM routing
# litellm | qwen_direct
LLM_MODE=litellm
LLM_FALLBACK_ENABLED=true

# Qwen direct (OpenAI-compatible endpoint)
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
# You can also use DASHSCOPE_API_KEY instead of QWEN_API_KEY
DASHSCOPE_API_KEY=
QWEN_TEMPERATURE=0.1
QWEN_TIMEOUT=60

LOG_LEVEL=INFO

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=a2ui-revenue-poc
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
