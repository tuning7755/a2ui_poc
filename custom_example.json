              "width": "800px",
              "height": "400px"
            },
            "dataBinding": {
              "resultData": [
                "/custom-chart/resultData"
              ],
              "legend": [
                "/custom-chart/legend/dim"
              ],
              "xAxis": [
                "/custom-chart/xAxis/dim"
              ],
              "yAxis": [
                "/custom-chart/yAxis/measure"
              ]
            },
            "action": {
              "name": "chartClick",
              "context": [
                {
                  "key": "chartType",
                  "value": {
                    "literalString": "line"
                  }
                }
              ]
            }
          }
        }
      }
    ]
